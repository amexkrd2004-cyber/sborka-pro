# Скопируйте в .env и заполните. Файл .env не коммитить.

PORT=3000

# МойСклад JSON API (вебхук + догрузка заказа по href)
# MOYSKLAD_TOKEN=
# Полный публичный URL эндпоинта (для npm run moysklad:register-webhooks), напр. https://….up.railway.app/webhook/moysklad
# MOYSKLAD_WEBHOOK_URL=
# Имя статуса заказа, при котором кладовщики должны увидеть заказ (как в МойСклад, точное совпадение)
# MOYSKLAD_ASSEMBLY_STATE_NAME=Сборка
# MOYSKLAD_ACCOUNT_ID=

# Секрет подписи JWT (фаза B), минимум 32 символа
# JWT_SECRET=

# Если настроите проверку подписи webhook — укажите тот же секрет, что в МойСклад (опционально)
# WEBHOOK_SECRET=

# Показывать полное тело webhook в логах (только для отладки локально; на проде лучше false)
# WEBHOOK_LOG_FULL_BODY=false

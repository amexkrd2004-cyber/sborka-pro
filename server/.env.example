# Скопируйте в .env и заполните. Файл .env не коммитить.

PORT=3000

# МойСклад API (понадобятся на фазе B)
# MOYSKLAD_TOKEN=
# MOYSKLAD_ACCOUNT_ID=

# Секрет подписи JWT (фаза B), минимум 32 символа
# JWT_SECRET=

# Если настроите проверку подписи webhook — укажите тот же секрет, что в МойСклад (опционально)
# WEBHOOK_SECRET=

# Показывать полное тело webhook в логах (только для отладки локально; на проде лучше false)
# WEBHOOK_LOG_FULL_BODY=false
